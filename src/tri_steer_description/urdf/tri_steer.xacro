<?xml version="1.0"?>
<robot name="tri_steer" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========== 参数 ========== -->
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="body_radius" value="0.05"/>
  <xacro:property name="body_height" value="0.05"/>

  <xacro:property name="wheel_damping" value="0.0001"/>
  <xacro:property name="wheel_friction" value="0.0001"/>

  <xacro:property name="wheel_effot" value="300"/>
  <xacro:property name="wheel_velocity" value="20"/>

  <xacro:property name="turn_effot" value="300"/>
  <xacro:property name="turn_velocity" value="10"/>


  <xacro:property name="pos_wheel_z" value="-0.045"/>
  
  <xacro:property name="turn_radius" value="0.1"/>
  <xacro:property name="turn_height" value="0.01"/> 



  <xacro:property name="lift_radius" value="0.1"/>
  <xacro:property name="lift_height" value="0.02"/>

  <!-- 轮子到车体中心的半径（决定转弯时轮速差） -->
  <!-- <xacro:property name="R" value="0.3535"/> -->

  <!-- ========== base ========== -->
  <link name="base_footprint"/> 

  <link
    name="base_link">
    <inertial>
      <origin
        xyz="0.008137 -0.0019645 -0.0037906"
        rpy="0 0 0" />
      <mass
        value="5.0701" />
      <inertia
        ixx="0.056129"
        ixy="-0.00012401"
        ixz="-5.0766E-05"
        iyy="0.054858"
        iyz="5.3268E-05"
        izz="0.10521" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://tri_steer_description/meshes2/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
       <cylinder radius="${turn_radius}" length="${turn_height}"/>
       </geometry>
    </collision>
  </link>

   <joint name="base_link_joint" type="fixed">
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint> 

  <!-- 舵轮 1 -->
  <link
    name="turn1">
    <inertial>
      <origin
        xyz="-8.1365E-05 0.00049252 0.088662"
        rpy="0 0 0" />
      <mass
        value="3.2924" />
      <inertia
        ixx="0.006991"
        ixy="-0.00016006"
        ixz="-1.731E-06"
        iyy="0.0076006"
        iyz="4.8359E-06"
        izz="0.012782" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://tri_steer_description/meshes2/turn1.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
  <origin xyz="0 0 0.05" rpy="0 0 0"/>
  <geometry><cylinder radius="${turn_radius}" length="${turn_height}"/></geometry>
  </collision>
  </link>
<joint
    name="joint11"
    type="continuous">
    <origin
      xyz="-0.35334 0 -0.055357"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="turn1" />
    <axis
      xyz="0 0 1" />
    <dynamics damping="${wheel_damping}" friction="${wheel_friction}"/>
    <limit effort="${turn_effot}" velocity="${turn_velocity}"/>
  </joint>
  
   <link
    name="wheel1">
    <inertial>
      <origin
        xyz="-2.9476E-14 -0.043943 3.5416E-14"
        rpy="0 0 0" />
      <mass
        value="0.28016" />
      <inertia
        ixx="0.00022144"
        ixy="2.6268E-18"
        ixz="2.7544E-19"
        iyy="0.00034522"
        iyz="-3.6931E-17"
        izz="0.00022144" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://tri_steer_description/meshes2/wheel1.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 -0.045 0"
        rpy="0 0 0" />
      <geometry>
       <sphere radius= "${wheel_radius}"/>
      </geometry>
    </collision>
  </link>
  <joint
    name="joint12"
    type="continuous">
    <origin
      xyz="0 0.045 -0.045"
      rpy="0 0 0" />
    <parent
      link="turn1" />
    <child
      link="wheel1" />
    <axis
      xyz="0 1 0" />
    <dynamics damping="${wheel_damping}" friction="${wheel_friction}" />
    <limit effort="${wheel_effot}" velocity="${wheel_velocity}" />  
  </joint>

 <link
    name="lift1">
    <inertial>
      <origin
        xyz="-0.00026898 0.0001523 -0.026187"
        rpy="0 0 0" />
      <mass
        value="0.54659" />
      <inertia
        ixx="0.0014575"
        ixy="-5.8921E-08"
        ixz="-1.1592E-07"
        iyy="0.0014564"
        iyz="6.7896E-07"
        izz="0.0026981" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://tri_steer_description/meshes2/lift1.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
    <origin xyz="0 0 -0.01" rpy="0 0 0"/>
      <geometry><cylinder radius="${lift_radius}" length="${lift_height}"/></geometry>
    </collision>
  </link>
  <joint
    name="joint13"
    type="prismatic">
    <origin
      xyz="0 0 0.201"
      rpy="0 0 0" />
    <parent
      link="turn1" />
    <child
      link="lift1" />
    <axis
      xyz="0 0 1" />
  <dynamics damping="0.2" friction="0.1"/>
  <limit lower="0" upper="0.05" effort="2000" velocity="0.1"/>

  </joint>


  <!-- 舵轮 2 -->
  <link
    name="turn2">
    <inertial>
      <origin
        xyz="-8.1358E-05 0.0004925 0.088662"
        rpy="0 0 0" />
      <mass
        value="3.2924" />
      <inertia
        ixx="0.006991"
        ixy="-0.00016006"
        ixz="-1.731E-06"
        iyy="0.0076006"
