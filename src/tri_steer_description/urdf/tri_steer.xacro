  </link>

  <joint
    name="joint32"
    type="continuous">
    <origin
      xyz="0 -0.045 -0.045"
      rpy="0 0 0" />
    <parent
      link="turn3" />
    <child
      link="wheel3" />
    <axis
      xyz="0 1 0" />
    <dynamics damping="${wheel_damping}" friction="${wheel_friction}"/>
    <limit effort="${wheel_effot}" velocity="${wheel_velocity}"/>
  </joint>

 <link
    name="lift3">
    <inertial>
      <origin
        xyz="-0.0001763 0.00025409 -0.026187"
        rpy="0 0 0" />
      <mass
        value="0.54658" />
      <inertia
        ixx="0.0014573"
        ixy="-4.7272E-07"
        ixz="1.8988E-07"
        iyy="0.0014566"
        iyz="6.7451E-07"
