  </joint>

<link
    name="wheel2">
    <inertial>
      <origin
        xyz="8.3822E-15 -0.046057 -1.0977E-14"
        rpy="0 0 0" />
      <mass
        value="0.28016" />
      <inertia
        ixx="0.00022144"
        ixy="2.419E-19"
        ixz="4.5831E-19"
        iyy="0.00034522"
        iyz="-7.1227E-17"
        izz="0.00022144" />
