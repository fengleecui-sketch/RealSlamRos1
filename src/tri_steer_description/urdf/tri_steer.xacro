    <parent
      link="base_link" />
    <child
      link="turn3" />
    <axis
      xyz="0 0 1" />
    <dynamics damping="${wheel_damping}" friction="${wheel_friction}"/>
    <limit effort="${turn_effot}" velocity="${turn_velocity}"/>
  </joint>

<link
    name="wheel3">
    <inertial>
      <origin
        xyz="5.3291E-15 0.043943 -1.1433E-13"
        rpy="0 0 0" />
      <mass
        value="0.28016" />
      <inertia
        ixx="0.00022144"
        ixy="-4.9652E-20"
        ixz="4.2165E-19"
