<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <!-- IMU + Lidar 融合里程计节点 -->
    <node pkg="robot_navigation" type="imu_lidar_fusion_odom.py" name="imu_lidar_fusion_odom" output="screen">
        <!-- 更新频率 (Hz) -->
        <param name="update_rate" value="50" />
        
        <!-- 融合模式: complementary (互补滤波) 或 ekf (扩展卡尔曼滤波简化版) -->
        <param name="fusion_mode" value="complementary" />
        
        <!-- 激光雷达权重 (0.0-1.0) - 用于位置估计 -->
        <param name="lidar_weight" value="0.7" />
        
        <!-- IMU权重 (0.0-1.0) - 用于角速度估计 -->
        <param name="imu_weight" value="0.3" />
    </node>
    
    <!-- 可选：可视化调试 -->
    <group if="$(arg debug)">
        <node pkg="robot_navigation" type="imu_lidar_fusion_odom.py" name="imu_lidar_debug" output="screen" launch-prefix="xterm -e gdb -ex run --args">
            <param name="update_rate" value="20" />
        </node>
    </group>
    
    <!-- 默认参数 -->
    <arg name="debug" default="false" />
    
</launch>
